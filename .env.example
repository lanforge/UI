# API — set to your deployed API domain
REACT_APP_API_URL=https://api.lanforge.co/api

# Stripe (publishable key — safe to expose)
REACT_APP_STRIPE_PUBLIC_KEY=pk_live_...

# Affirm
REACT_APP_AFFIRM_PUBLIC_KEY=
REACT_APP_AFFIRM_SCRIPT_URL=https://cdn1.affirm.com/js/v2/affirm.js

# PayPal (client ID — safe to expose)
REACT_APP_PAYPAL_CLIENT_ID=

# Google Maps (safe to expose, restrict by domain in Google Cloud Console)
REACT_APP_GOOGLE_MAPS_API_KEY=
